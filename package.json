{
  "name": "payload-admin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node --experimental-strip-types scripts/copy-assets.ts",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "prebuild": "node --experimental-strip-types scripts/copy-assets.ts",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "deploy": "vercel",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@payloadcms/db-postgres": "^3.80.0",
    "@payloadcms/drizzle": "3.80.0",
    "@payloadcms/next": "3.80.0",
    "@payloadcms/richtext-lexical": "3.80.0",
    "@payloadcms/storage-s3": "^3.80.0",
    "@payloadcms/ui": "3.80.0",
    "cross-env": "^10.1.0",
    "dotenv": "17.3.1",
    "next": "^16.2.3",
    "payload": "3.80.0",
    "payload-config": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "jsdom": "29.0.1",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": "^24.13.0",
    "pnpm": "^10"
  }
}